# Tactical Edge — zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości

# Klucz API do pobierania kursów (the-odds-api.com lub podobny)
TACTICAL_EDGE_ODDS_API_KEY=your_key_here

# Kapitał w bankrollu (PLN/EUR/USD)
TACTICAL_EDGE_BANKROLL=2000

# Frakcja Kelly (0.25 = quarter Kelly, bezpieczne)
TACTICAL_EDGE_KELLY_FRACTION=0.25

# Minimalny edge wymagany do zakładu (0.03 = 3%)
TACTICAL_EDGE_MIN_EDGE=0.03

# Minimalna zgodność modeli (0.60 = 60%)
TACTICAL_EDGE_MIN_AGREEMENT=0.60

# Liczba symulacji Monte Carlo
TACTICAL_EDGE_N_SIMS=10000
